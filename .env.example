# ========================================
# DOCK-NAV PORTFOLIO OS — Environment Config
# Copy this file to .env and fill in values
# NEVER commit .env to version control
# ========================================

# ---- Application ----
APP_NAME="Mudassir's Portfolio"
APP_URL=http://localhost/portfolio
APP_ENV=development
APP_DEBUG=false

# ---- Database ----
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=portfolio_db
DB_USER=root
DB_PASS=

# ---- Session ----
SESSION_NAME=portfolio_sess
SESSION_LIFETIME=86400

# ---- Auth ----
JWT_SECRET=change_this_to_a_random_64char_string_in_production
ADMIN_EMAIL=mudassir@example.com

# ---- Mail (PHPMailer SMTP) ----
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM=your@gmail.com
MAIL_FROM_NAME="Mudassir Portfolio"

# ---- Uploads ----
UPLOAD_MAX_CV_SIZE=5242880
UPLOAD_MAX_IMG_SIZE=3145728
CV_RETENTION_DAYS=30

# ---- Rate Limiting ----
RATE_LIMIT_LOGIN=5
RATE_LIMIT_LOGIN_WINDOW=900
RATE_LIMIT_CONTACT=5
RATE_LIMIT_CONTACT_WINDOW=3600

# ---- Security ----
CSRF_TOKEN_LENGTH=64
LOCKOUT_THRESHOLD=5
LOCKOUT_DURATION=900
